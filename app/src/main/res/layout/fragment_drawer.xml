<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark_2"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Velaud"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_extrabold"
            android:letterSpacing="-0.03"/>
    </LinearLayout>

    <!-- Search -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_search_field"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="6dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="11dp"
        android:paddingBottom="11dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_search"
            android:tint="@color/muted"/>
        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:background="@null"
            android:hint="Ara"
            android:hintTextColor="@color/muted_2"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:singleLine="true"
            android:fontFamily="@font/inter_regular"/>
    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="10dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Nav Items -->
            <LinearLayout
                android:id="@+id/navChats"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/bg_nav_item"
                android:clickable="true"
                android:focusable="true">
                <ImageView android:layout_width="21dp" android:layout_height="21dp"
                    android:src="@drawable/ic_chat" android:tint="@color/text_primary"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="14dp" android:text="Sohbetler"
                    android:textColor="@color/text_primary" android:textSize="16sp"
                    android:textStyle="bold" android:fontFamily="@font/inter_semi"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navProjects"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/bg_nav_item"
                android:clickable="true"
                android:focusable="true">
                <ImageView android:layout_width="21dp" android:layout_height="21dp"
                    android:src="@drawable/ic_projects" android:tint="@color/text_primary"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="14dp" android:text="Projeler"
                    android:textColor="@color/text_primary" android:textSize="16sp"
                    android:textStyle="bold" android:fontFamily="@font/inter_semi"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navFiles"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/bg_nav_item"
                android:clickable="true"
                android:focusable="true">
                <ImageView android:layout_width="21dp" android:layout_height="21dp"
                    android:src="@drawable/ic_files" android:tint="@color/text_primary"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="14dp" android:text="Dosyalarınız"
                    android:textColor="@color/text_primary" android:textSize="16sp"
                    android:textStyle="bold" android:fontFamily="@font/inter_semi"/>
            </LinearLayout>

            <!-- Section label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="16dp"
                android:text="SOHBETLER"
                android:textColor="@color/muted_2"
                android:textSize="12.5sp"
                android:textStyle="bold"
                android:fontFamily="@font/inter_semi"
                android:letterSpacing="0.04"/>

            <!-- Chat history list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvChats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </ScrollView>

    <!-- Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="14dp"
        android:background="@drawable/bg_drawer_footer">

        <TextView
            android:id="@+id/tvProfileInitial"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:gravity="center"
            android:text="U"
            android:textColor="@color/bg_dark"
            android:textSize="19sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_extrabold"
            android:background="@drawable/bg_profile_circle"
            android:clickable="true"
            android:focusable="true"/>

        <Button
            android:id="@+id/btnNewChat"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Yeni Sohbet"
            android:textColor="@color/bg_dark"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="@font/inter_bold"
            android:background="@drawable/bg_new_chat_btn"
            android:stateListAnimator="@null"
            android:drawableStart="@drawable/ic_plus"
            android:drawableTint="@color/bg_dark"
            android:drawablePadding="8dp"/>
    </LinearLayout>

</LinearLayout>

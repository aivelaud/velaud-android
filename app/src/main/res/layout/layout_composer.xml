<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_composer"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="10dp">

        <!-- Text input -->
        <EditText
            android:id="@+id/etMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="36dp"
            android:maxHeight="120dp"
            android:background="@null"
            android:hint="Ask Velaud Agent"
            android:hintTextColor="@color/muted_2"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:fontFamily="@font/inter_regular"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="4"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="4dp"
            android:paddingBottom="8dp"/>

        <!-- Bottom row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Left tools -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Plus button (white circle) -->
                <ImageButton
                    android:id="@+id/btnPlus"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_btn_white_circle"
                    android:src="@drawable/ic_plus"
                    android:tint="@color/bg_dark"
                    android:padding="9dp"/>

                <!-- Model pill -->
                <LinearLayout
                    android:id="@+id/btnModelPill"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_model_pill"
                    android:paddingStart="8dp"
                    android:paddingEnd="12dp"
                    android:layout_marginStart="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@mipmap/ic_launcher"
                        android:background="@drawable/bg_logo_tiny"/>

                    <TextView
                        android:id="@+id/tvCurrentModel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="7dp"
                        android:text="Claude Opus 4.7"
                        android:textColor="@color/text_primary"
                        android:textSize="13.5sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/inter_semi"
                        android:maxWidth="150dp"
                        android:singleLine="true"
                        android:ellipsize="end"/>

                    <ImageView
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:layout_marginStart="6dp"
                        android:src="@drawable/ic_chevron_down"
                        android:tint="@color/muted"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Send button -->
            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_send_inactive"
                android:src="@drawable/ic_send"
                android:padding="9px"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
